<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="App\Domain\Entity\UserOrders" table="user_orders">
        <id name="id" type="integer">
            <generator strategy="AUTO"/>
        </id>

        <many-to-one field="user" target-entity="App\Domain\Entity\User" inversed-by="userOrders">
            <join-column name="user_id_id" referenced-column-name="id" nullable="false"/>
        </many-to-one>

        <field name="totalPrice" column="total_price" type="decimal" precision="10" scale="2" nullable="true"/>
        <field name="createdAt" column="created_at" type="datetime_immutable" nullable="true"/>
    </entity>
</doctrine-mapping>
